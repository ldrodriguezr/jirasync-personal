diff --git a/supabase/migrations/004_github_sync.sql b/supabase/migrations/004_github_sync.sql
new file mode 100644
index 0000000..7dbb045
--- /dev/null
+++ b/supabase/migrations/004_github_sync.sql
@@ -0,0 +1,39 @@
+-- ────────────────────────────────────────────────────────────────────────────
+-- 004 · GitHub sync
+-- Stores per-project GitHub connection settings and tracks synced items.
+-- ────────────────────────────────────────────────────────────────────────────
+
+create table if not exists jira.github_settings (
+  id            uuid primary key default gen_random_uuid(),
+  project_id    uuid not null unique references jira.projects(id) on delete cascade,
+  owner         text not null,               -- GitHub org or user name
+  repo          text not null,               -- repository name
